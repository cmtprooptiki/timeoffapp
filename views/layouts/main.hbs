<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Open source Staff Time off management system">
    <meta name="google-site-verification" content="DUsMFaxswq0M9hZwfzXPVMP56hDyUDG_0bLDZFR6zA4" />
    <link rel="icon" href="/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" type="text/css" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"/>

    <title>{{title}}</title>

    <!-- Bootstrap core CSS -->
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/font-awesome.min.css">

    <!-- Custom styles for this template -->
    <link rel='stylesheet' href='/css/style.css' />
    <!-- Modern Liquid Glass Design -->
    <link rel='stylesheet' href='/css/modern.css' />
    {{#each custom_css}}
    <link rel="stylesheet" href="{{this}}" />
    {{/each}}
  </head>

  <body>
    <!-- Animated background orbs -->
    <div class="bg-anim" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
      <div class="orb orb-6"></div>
    </div>
    <div class="container">
    {{{body}}}
    </div>

    <script src="/js/jquery.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <script>
      // Colour-code leave status badges
      $(function(){
        $('.leave-request-row-status').each(function(){
          var t = $(this).text().trim().toLowerCase();
          if (t === 'approved')  $(this).css({'background':'rgba(52,199,89,0.12)','color':'#1a7f37'});
          if (t === 'pending')   $(this).css({'background':'rgba(255,149,0,0.12)','color':'#9a5f00'});
          if (t === 'rejected')  $(this).css({'background':'rgba(255,59,48,0.12)','color':'#c0392b'});
        });
      });
    </script>
    {{~#each custom_java_script~}}
      <script src="{{this}}"></script>
    {{~/each~}}

    {{~# is_ga_analitics_on ~}}
      <script>
        (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
        })(window,document,'script','//www.google-analytics.com/analytics.js','ga');
        ga('create', 'UA-63733147-1', 'auto');
        ga('send', 'pageview');
      </script>
    {{~/ is_ga_analitics_on ~}}

  </body>
</html>
