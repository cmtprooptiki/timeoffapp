              <a id="me_menu" href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="false">Εγώ <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li><a href="/requests/">Αιτήματα</a></li>
                <li class="hidden-xs"><a href="/calendar/feeds/">Ροές</a></li>
                <li role="separator" class="divider hidden-xs"></li>
                <li><a href="/logout/">Αποσύνδεση</a></li>
              </ul>
            </li>
          {{else}}
            <li><a href="/login/">Σύνδεση</a></li>
          {{/if}}
        </li>
      </ul>
    </div><!-- /.navbar-collapse -->
  </div><!-- /.container-fluid -->
</nav>

{{# if logged_user }}
  {{# if logged_user.company.company_wide_message  }}
    <div class="alert alert-danger" role="alert">{{ logged_user.company.company_wide_message }}</div>
  {{/if}}
{{/if}}

</div>


