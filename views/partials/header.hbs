                <span class="fa fa-bell-o"></span>
                <span class="label label-info notification-badge hidden"></span>
              </a>
              <ul class="dropdown-menu" role="menu">
                <li class="dropdown-header">Δεν υπάρχουν ειδοποιήσεις</li>
              </ul>
            </li>
            {{#if logged_user.admin }}
            <li class="dropdown hidden-xs">
              <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="false"><span class="fa fa-gears"></span> <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li><a href="/settings/general/">Γενικά</a></li>
                <li role="separator" class="divider"></li>
                <li><a href="/settings/departments/">Τμήματα</a></li>
                <li><a href="/settings/bankholidays/">Αργίες</a></li>
                <li><a href="/settings/company/authentication/">Ρύθμιση LDAP</a></li>
                <li><a href="/settings/company/integration-api/">Ρύθμιση API</a></li>
                <li><a href="/users/import/">Εισαγωγή υπαλλήλων</a></li>
                <li role="separator" class="divider"></li>
                <li><a href="/audit/email/">Έλεγχος email</a></li>
                <li><a href="/reports/">Αναφορές</a></li>
              </ul>
            </li>
            {{/if}}
            <li class="visible-xs-block"><a href="/requests/">Αιτήματα</a></li>
            <li class="visible-xs-block"><a href="/logout/">Αποσύνδεση</a></li>
